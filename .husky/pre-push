echo "Building project..."
pnpm build

if [ $? -ne 0 ]; then
  echo "Build failed! Please fix the errors before pushing."
  exit 1
fi

echo "Build successful!"

echo ""
echo "Running tests (skip with SKIP_TESTS=true)..."
if [ "$SKIP_TESTS" = "true" ]; then
  echo "Tests skipped (SKIP_TESTS=true)"
else
  pnpm test
  if [ $? -ne 0 ]; then
    echo "Tests failed! Please fix the failing tests before pushing."
    echo "To skip tests, run: SKIP_TESTS=true git push"
    exit 1
  fi
  echo "All tests passed!"
fi

echo ""
echo "Running examples (skip with SKIP_EXAMPLES=true)..."
if [ "$SKIP_EXAMPLES" = "true" ]; then
  echo "Examples skipped (SKIP_EXAMPLES=true)"
else
  pnpm test:examples
  if [ $? -ne 0 ]; then
    echo "Examples failed! Please fix the failing examples before pushing."
    echo "To skip examples, run: SKIP_EXAMPLES=true git push"
    exit 1
  fi
  echo "All examples passed!"
fi

echo ""
echo "Ready to push!"
